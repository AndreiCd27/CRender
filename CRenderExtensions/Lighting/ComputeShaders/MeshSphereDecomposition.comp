#version 430 core

layout(local_size_x = 4, local_size_y = 4, local_size_z = 4) in;

uniform sampler3D VoxelTex;
uniform isampler3D InstanceTex;
uniform int LODmax;

struct Sphere {
    vec4 pos_rad; 
    ivec4 instanceID;
};

layout(std430, binding = 0) writeonly buffer SphereBuffer {
    uint sphereCount;
    uint pad0;
    uint pad1;
    uint pad2;
    Sphere spheres[];
};

int GetInstance(ivec3 minPos, int size, ivec3 gridRes) {
    
    // Look into the instanceID 3D texture
    // We have to round the result to prevent hardware interpolation errors

    ivec3 center = clamp(minPos + ivec3(size / 2), ivec3(0), gridRes - 1);
    int id = texelFetch(InstanceTex, center, 0).r;
    if (id >= 0) return id;
    return texelFetch(InstanceTex, clamp(minPos, ivec3(0), gridRes - 1), 0).r;
}

void main() {

    // This thread runs PER-VOXEL (4x4x4 area of voxels evaluated per work group)

    ivec3 gridRes = textureSize(InstanceTex, 0); 
    ivec3 voxelPos = ivec3(gl_GlobalInvocationID);
    if (voxelPos.x >= gridRes.x || voxelPos.y >= gridRes.y || voxelPos.z >= gridRes.z) return;

    // Threshold for noise, if the voxel is ALMOST empty, discard
    float baseFill = texelFetch(VoxelTex, voxelPos, 0).r;
    if (baseFill <= 0.05) return; 

    int targetLOD = 0;
    ivec3 targetMinPos = voxelPos;
    float finalFill = baseFill;

    // Sphere Accept Threshold, a value bigger than MERGE_THRESHOD in fill value accepts the sphere
    const float MERGE_THRESHOLD = 0.50; 

    // Start with Level Of Detail MAX and decrease it
    // Each LOD coresponds to a 2^LOD x 2^LOD x 2^LOD size voxel
    // LOD = 0 => voxel is at base size
    // For each voxel at any LOD try to put a sphere inside if the AREA is almost full
    // GPU combines fill values for every LOD

    // Only look till LOD = 1 to save time

    for (int lod = LODmax; lod > 0; lod--) {
        int size = 1 << lod;
        ivec3 lodMinPos = (voxelPos / size) * size;
        
        vec3 uvw = (vec3(lodMinPos) + vec3(float(size) * 0.5)) / vec3(gridRes);
        float mipFill = textureLod(VoxelTex, uvw, lod).r;

        // If region is sufficiently big, merge into a bigger sphere
        if (mipFill >= MERGE_THRESHOLD) {
            targetLOD = lod;
            targetMinPos = lodMinPos;
            finalFill = mipFill;
            break; 
        }
    }

    // Only ONE thread writes to the buffer (to avoid race conditions)
    //

    if (voxelPos == targetMinPos) {
        int instanceID = GetInstance(targetMinPos, 1 << targetLOD, gridRes);
        
        if (instanceID >= 0) {
            uint idx = atomicAdd(sphereCount, 1);
            
            if (idx < 100000) {
                int currentSize = 1 << targetLOD;
                vec3 centerVoxel = vec3(targetMinPos) + vec3(float(currentSize) * 0.5);
                vec3 normCoord = centerVoxel / vec3(gridRes);

                // Scale the sphere radius by cuberoot(fill)
                // This scales the spheres correctly to not create too big shadow volumes

                float volumeCorrection = pow(finalFill, 0.33333);
                float radius = (float(currentSize) / float(gridRes.x)) * 0.5 * volumeCorrection;

                spheres[idx].pos_rad = vec4(normCoord, radius);
                spheres[idx].instanceID = ivec4(instanceID, 0, 0, 0);
            }
        }
    }
}
